{
  "extends": "../../config/tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "downlevelIteration": true,
    "module": "CommonJS",
    "target": "ES6",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "typeRoots": ["../../node_modules/@types", "./node_modules/@types"]
  },
  "exclude": ["dist/**/*"]
}